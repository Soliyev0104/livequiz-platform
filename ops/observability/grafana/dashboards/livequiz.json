{
  "uid": "livequiz-main",
  "title": "LiveQuiz Platform",
  "tags": ["livequiz", "p10"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "editable": true,
  "graphTooltip": 1,
  "description": "LiveQuiz observability overview. Alert-like thresholds to watch (not wired to Alertmanager): (1) outbox_unpublished_total > 100 for 5m; (2) API p95 (http_request_duration_seconds) > 0.5s for 5m; (3) stream_worker_event_lag_seconds > 60; (4) Redis unavailable (up{job=\"redis-exporter\"} == 0).",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "API requests / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_request_duration_seconds_count[1m]))", "legendFormat": "all" },
        { "refId": "B", "expr": "sum by (handler) (rate(http_request_duration_seconds_count[1m]))", "legendFormat": "{{handler}}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "API p95 latency by route",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 5 }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.5 } ] } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, handler) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{handler}}" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "overall p95" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Active WebSocket connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 15, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (job, instance) (ws_connections_active)", "legendFormat": "{{instance}}" },
        { "refId": "B", "expr": "sum(ws_connections_active)", "legendFormat": "total" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Answer submissions / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (correct) (rate(quiz_answer_submissions_total[1m]))", "legendFormat": "correct={{correct}}" },
        { "refId": "B", "expr": "sum(rate(quiz_answer_submissions_total[1m]))", "legendFormat": "all" }
      ]
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Outbox backlog (unpublished events)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 25 }, { "color": "red", "value": 100 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        { "refId": "A", "expr": "max(outbox_unpublished_total)", "legendFormat": "unpublished" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Stream worker event lag (seconds)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 60 } ] } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "max by (topic) (stream_worker_event_lag_seconds)", "legendFormat": "{{topic}}" },
        { "refId": "B", "expr": "max(stream_worker_event_lag_seconds)", "legendFormat": "max" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Redis — memory used & commands / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 8 } }, "overrides": [ { "matcher": { "id": "byName", "options": "commands/sec" }, "properties": [ { "id": "unit", "value": "ops" }, { "id": "custom.axisPlacement", "value": "right" } ] }, { "matcher": { "id": "byName", "options": "memory used" }, "properties": [ { "id": "unit", "value": "bytes" } ] } ] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "redis_memory_used_bytes", "legendFormat": "memory used" },
        { "refId": "B", "expr": "rate(redis_commands_processed_total[1m])", "legendFormat": "commands/sec" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Postgres — active connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(pg_stat_database_numbackends)", "legendFormat": "backends" },
        { "refId": "B", "expr": "pg_settings_max_connections", "legendFormat": "max_connections" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "ClickHouse inserts / sec (via stream worker)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (event_type) (rate(stream_worker_events_processed_total[1m]))", "legendFormat": "{{event_type}}" },
        { "refId": "B", "expr": "sum(rate(stream_worker_events_processed_total[1m]))", "legendFormat": "all events" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "HTTP responses / sec by status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 12, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (status) (rate(http_request_duration_seconds_count[1m]))", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 11,
      "type": "logs",
      "title": "API logs (live)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "options": { "showTime": true, "showLabels": false, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [
        { "refId": "A", "expr": "{service=~\"api.*\"}", "queryType": "range" }
      ]
    }
  ]
}
