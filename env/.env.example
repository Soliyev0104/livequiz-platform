# =============================================================================
# LiveQuiz environment example. Copy to .env at repo root before `docker compose up`.
#   cp env/.env.example .env
# Never commit a real .env. All secrets here are placeholders.
# =============================================================================

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost

# --- Database (Postgres) ---
DATABASE_URL=postgresql+asyncpg://livequiz:livequiz@postgres:5432/livequiz

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Redpanda (Kafka API) ---
REDPANDA_BOOTSTRAP_SERVERS=redpanda:9092

# --- ClickHouse ---
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DB=livequiz

# --- Auth / JWT ---
JWT_SECRET=change_me
JWT_REFRESH_SECRET=change_me
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# --- Snowflake ID generator ---
# Custom epoch = 2026-01-01T00:00:00Z. Worker IDs are unique per replica.
#   api-a=1, api-b=2, outbox-publisher=10, stream-worker=20, scheduler=30, tests=9
SNOWFLAKE_WORKER_ID=1
SNOWFLAKE_EPOCH_MS=1767225600000

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=admin
