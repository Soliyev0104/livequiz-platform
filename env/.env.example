# =============================================================================
# LiveQuiz environment example. Copy to .env at repo root before `docker compose up`.
#   cp env/.env.example .env
# Never commit a real .env. All secrets here are placeholders.
# =============================================================================

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost
# Host port the nginx gateway publishes. Override if 80 is taken (e.g. 8888).
NGINX_PORT=80
# HTTP-only prod uses prod.conf. Domain + TLS uses prod.tls.conf plus docker-compose.tls.yml.
NGINX_CONF=prod.conf
NGINX_HTTPS_PORT=443
NGINX_CERTS_DIR=/etc/letsencrypt/live/example.com

# --- Database (Postgres) ---
POSTGRES_USER=livequiz
POSTGRES_PASSWORD=livequiz
POSTGRES_DB=livequiz
DATABASE_URL=postgresql+asyncpg://livequiz:livequiz@postgres:5432/livequiz
POSTGRES_EXPORTER_DATA_SOURCE_NAME=postgresql://livequiz:livequiz@postgres:5432/livequiz?sslmode=disable

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Redpanda (Kafka API) ---
REDPANDA_BOOTSTRAP_SERVERS=redpanda:9092

# --- ClickHouse ---
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DB=livequiz
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# --- Auth / JWT ---
JWT_SECRET=change_me
JWT_REFRESH_SECRET=change_me
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# --- Snowflake ID generator ---
# Custom epoch = 2026-01-01T00:00:00Z. Worker IDs are unique per replica.
#   api-a=1, api-b=2, outbox-publisher=10, stream-worker=20, scheduler=30, tests=9
SNOWFLAKE_WORKER_ID=1
SNOWFLAKE_EPOCH_MS=1767225600000

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# --- Grafana ---
# UI at http://localhost:3001 (login with these). Anonymous viewer access
# is also enabled for quick demos.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
